# Vendetta Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git!

# Deployer private key (Base Sepolia / Mainnet)
PRIVATE_KEY=YOUR_PRIVATE_KEY_HIER

# RPC endpoints
BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY_HIER
BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY_HIER

# Alchemy API key (for Flutter app)
ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY_HIER

# Basescan API key (for contract verification)
BASESCAN_API_KEY=YOUR_BASESCAN_KEY_HIER

# The Graph (deployment)
GRAPH_AUTH_TOKEN=YOUR_GRAPH_TOKEN_HIER

# IFR Token (ETH Mainnet)
IFR_CONTRACT=0x77e99917Eca8539c62F509ED1193ac36580A6e7B
